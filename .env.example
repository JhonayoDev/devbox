# ─────────────────────────────────────────────────────────────
#  .env.example
#  Copiá este archivo como .env y completá los valores.
#  El .env NUNCA se sube a git (está en .gitignore).
# ─────────────────────────────────────────────────────────────

# ── Usuario dentro del contenedor ─────────────────────────────
# Debe coincidir con tu UID/GID del host para evitar
# problemas de permisos en los volúmenes montados.
# Obtené los tuyos con: id -u && id -g
DEV_USERNAME=juan
DEV_UID=1000
DEV_GID=1000

# ── Tu repo de dotfiles ────────────────────────────────────────
# Dejalo vacío si no querés clonar dotfiles en el build.
# Ej: https://github.com/tuusuario/dotfiles.git
DOTFILES_REPO=https://github.com/tuusuario/dotfiles.git

# ── Ruta de tus proyectos en el HOST ──────────────────────────
# Esta carpeta se monta como volumen en ~/dev dentro del contenedor.
# Usá ruta absoluta para evitar ambigüedades.
# En tu PC local puede ser tu carpeta ~/dev normal.
# En el servidor, la misma lógica.
DEV_PROJECTS_PATH=/home/juan/dev

# ── Puerto SSH expuesto ────────────────────────────────────────
# En tu PC local: 2222 (para no pisar el SSH del host)
# En el servidor: podés usar otro puerto libre, ej: 2223
SSH_PORT=2222

# ── Ruta a tu authorized_keys ─────────────────────────────────
# Archivo con tu(s) clave(s) pública(s) SSH.
# Generalmente es: ~/.ssh/authorized_keys
# O podés crear uno específico para este contenedor.
# Usá ruta absoluta.
SSH_AUTHORIZED_KEYS_PATH=/home/juan/.ssh/authorized_keys

# ── Timezone ──────────────────────────────────────────────────
TIMEZONE=America/Argentina/Buenos_Aires
