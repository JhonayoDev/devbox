# ─────────────────────────────────────────────────────────────
#  env.example
#  Copiá este archivo como .env y completá los valores.
#  El .env NUNCA se sube a git (está en .gitignore).
#
#  Comandos útiles:
#    id -u   → tu UID
#    id -g   → tu GID
# ─────────────────────────────────────────────────────────────
CONTAINER_NAME:devbox
# ── Usuario dentro del contenedor ─────────────────────────────
# Debe coincidir con tu UID/GID del host para evitar
# problemas de permisos en los volúmenes montados.
DEV_USERNAME=user
DEV_UID=1000
DEV_GID=1000

# ── Repo de dotfiles ───────────────────────────────────────────
# El Dockerfile lo clona durante el build y corre install.sh devbox.
# Dejalo vacío si no querés clonar dotfiles en el build.
DOTFILES_REPO=git@github.com:tuUsuario/dotfiles.git

# ── Proyectos ──────────────────────────────────────────────────
# Ruta absoluta en el host que se monta como ~/dev en el contenedor.
# El código vive en el host — si recreás el contenedor, no se pierde.
DEV_PROJECTS_PATH=/home/user/dev

# ── SSH ────────────────────────────────────────────────────────
# Puerto expuesto para conectarte al devbox.
# PC local: 2222 (para no pisar el SSH del host)
# Servidor: otro puerto libre, ej: 2223
SSH_PORT=2222

# Ruta a tu archivo authorized_keys en el host.
# Contiene tu(s) clave(s) pública(s) SSH.
SSH_AUTHORIZED_KEYS_PATH=/home/user/.ssh/authorized_keys

# ── Timezone ───────────────────────────────────────────────────
TIMEZONE=America/Santiago

# ── Servicios del servidor (opcional) ─────────────────────────
# Si definís esta variable, el volumen se activa y podés editar
# los docker-compose de tus servicios con nvim desde el devbox.
# Requiere descomentar el volumen correspondiente en docker-compose.yml.
# Dejalo comentado si no aplica en este entorno (ej: PC local).
# SERVER_SERVICES_PATH=/opt/docker

# ─────────────────────────────────────────────────────────────
# ── Features ───────────────────────────────────────────────────
FEATURES_REPO:git@github.com:tuUsuario/devbox-features.git
# ─────────────────────────────────────────────────────────────
# ── Features config ─────────────────────────────────────────
JAVA_VERSIONS=21.0.8-tem 17.0.16-tem 8.0.482-tem
JAVA_DEFAULT=21.0.8-tem
# ── MySQL ──────────────────────────────────────────────────────
MYSQL_ROOT_PASSWORD=rootpassword
MYSQL_DATABASE=devdb
MYSQL_USER=dev
MYSQL_PASSWORD=devpassword
MYSQL_PORT=3306

# ── PostgreSQL ─────────────────────────────────────────────────
POSTGRES_DB=devdb
POSTGRES_USER=dev
POSTGRES_PASSWORD=devpassword
POSTGRES_PORT=5432

# ── Redis ──────────────────────────────────────────────────────
REDIS_PORT=6379
